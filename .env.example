# WebSocket RPC endpoints, comma-separated in failover order. The listener
# rotates to the next one after 3 consecutive failed reconnects — public
# nodes sometimes block a cloud provider's whole egress range.
# (Singular RPC_WSS_URL is also accepted.)
RPC_WSS_URLS=wss://ethereum-rpc.publicnode.com,wss://eth.drpc.org,wss://eth.llamarpc.com

# HTTP RPC endpoints for gap backfill (eth_getLogs); retries rotate through
# the list. (Singular RPC_HTTP_URL is also accepted.)
RPC_HTTP_URLS=https://ethereum-rpc.publicnode.com,https://eth.drpc.org,https://eth.llamarpc.com

# Contract to index (default: USDC on Ethereum mainnet)
CONTRACT_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48

# Redis connection
REDIS_URL=redis://localhost:6379

# HTTP port for /healthz, /api/metrics and the dashboard
PORT=3000

# Log level: debug | info | warn | error
LOG_LEVEL=info
