# WebSocket RPC endpoint (primary). Public endpoints work fine.
RPC_WSS_URL=wss://ethereum-rpc.publicnode.com

# HTTP RPC endpoint — used for gap backfill (eth_getLogs) after reconnects.
RPC_HTTP_URL=https://ethereum-rpc.publicnode.com

# Contract to index (default: USDC on Ethereum mainnet)
CONTRACT_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48

# Redis connection
REDIS_URL=redis://localhost:6379

# HTTP port for /healthz, /api/metrics and the dashboard
PORT=3000

# Log level: debug | info | warn | error
LOG_LEVEL=info
